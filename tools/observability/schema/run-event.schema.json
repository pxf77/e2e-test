{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://huize.example/schemas/run-event.schema.json",
  "title": "RunEvent",
  "description": "Unified observability event for skill phases, runtime actions, tool calls and Playwright execution.",
  "type": "object",
  "required": [
    "schema_version",
    "event_id",
    "run_id",
    "trace_id",
    "kind",
    "event_type",
    "actor_type",
    "status",
    "product_id",
    "occurred_at"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "event_id": {
      "type": "string",
      "pattern": "^evt_[A-Za-z0-9_-]+$"
    },
    "run_id": {
      "type": "string",
      "pattern": "^run_[A-Za-z0-9_-]+$"
    },
    "trace_id": {
      "type": "string",
      "pattern": "^trace_[A-Za-z0-9_-]+$"
    },
    "parent_event_id": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^evt_[A-Za-z0-9_-]+$"
    },
    "kind": {
      "type": "string",
      "enum": [
        "run",
        "skill",
        "phase",
        "action",
        "tool_call",
        "artifact",
        "user_gate",
        "guardrail",
        "test_case",
        "debug_snapshot"
      ]
    },
    "event_type": {
      "type": "string"
    },
    "actor_type": {
      "type": "string",
      "enum": [
        "system",
        "skill",
        "agent",
        "tool",
        "playwright",
        "user",
        "guardrail",
        "parser"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "started",
        "completed",
        "failed",
        "blocked",
        "warning",
        "waiting",
        "skipped",
        "cancelled",
        "observed",
        "unobserved"
      ]
    },
    "product_id": {
      "type": "string",
      "minLength": 1
    },
    "skill_name": {
      "type": [
        "string",
        "null"
      ]
    },
    "phase_name": {
      "type": [
        "string",
        "null"
      ]
    },
    "title": {
      "type": [
        "string",
        "null"
      ]
    },
    "summary": {
      "type": [
        "string",
        "null"
      ]
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "started_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "ended_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "duration_ms": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "artifact_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "input_ref": {
      "type": [
        "object",
        "null"
      ]
    },
    "output_ref": {
      "type": [
        "object",
        "null"
      ]
    },
    "error_code": {
      "type": [
        "string",
        "null"
      ]
    },
    "error_message": {
      "type": [
        "string",
        "null"
      ]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "metrics": {
      "type": [
        "object",
        "null"
      ]
    },
    "data": {
      "type": [
        "object",
        "null"
      ]
    }
  }
}
