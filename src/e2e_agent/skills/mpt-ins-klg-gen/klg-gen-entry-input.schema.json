{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "mpt-ins-klg-gen entry input",
  "type": "object",
  "required": ["product_id"],
  "properties": {
    "product_id": { "type": "string" },
    "product_name": { "type": "string" },
    "root_dir": { "type": "string" },
    "materialise": { "type": "boolean" },
    "prd_analysis": { "type": "object" },
    "workflow_cases": {
      "type": "object",
      "properties": {
        "cases": {
          "type": "array",
          "items": { "type": "object" }
        }
      },
      "additionalProperties": true
    },
    "entry_url": { "type": "string" },
    "exploration_mode": { "type": "string" },
    "page_probe": { "type": "object" },
    "page_probe_fail_fast": { "type": "boolean" },
    "headless": { "type": "boolean" },
    "viewport": {
      "type": "object",
      "properties": {
        "width": { "type": "integer" },
        "height": { "type": "integer" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
