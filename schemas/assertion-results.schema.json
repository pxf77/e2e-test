{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "assertion-results.schema.json",
  "title": "AssertionResults",
  "description": "exec_agent 产出 — 断言执行结果列表",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["assertion_id", "case_id", "template_type", "status", "actual_value"],
    "additionalProperties": false,
    "properties": {
      "assertion_id": { "type": "string" },
      "case_id": { "type": "string" },
      "template_type": {
        "type": "string",
        "enum": ["price_premium", "underwriting_result", "order_status", "custom"],
        "description": "必须来自 assertion-templates.yaml（custom 需附 justification）"
      },
      "status": {
        "type": "string",
        "enum": ["pass", "fail", "skip", "error"]
      },
      "expected_value": {},
      "actual_value": {},
      "fact_lineage": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "version": { "type": "string" },
          "scenario_id": { "type": "string" },
          "path_id": { "type": "string" },
          "case_ids": { "type": "array", "items": { "type": "string" } },
          "test_data_profile_ids": { "type": "array", "items": { "type": "string" } },
          "action_evidence": { "type": "object", "additionalProperties": true },
          "assertion_refs": { "type": "array", "items": { "type": "string" } },
          "terminal_boundary": { "type": "object", "additionalProperties": true },
          "coverage_status": { "type": "string" },
          "contract_status": { "type": "string" }
        }
      },
      "error_message": { "type": ["string", "null"] },
      "screenshot_path": { "type": ["string", "null"] },
      "template_source": { "type": "string" },
      "match_reason": { "type": "string" },
      "variables": { "type": "object" },
      "assertion_strength": {
        "type": "string",
        "enum": ["strong", "weak"]
      },
      "weak": { "type": "boolean" },
      "justification": { "type": ["string", "null"] },
      "missing_template_reason": { "type": ["string", "null"] }
    }
  }
}
