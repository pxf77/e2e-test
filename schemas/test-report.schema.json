{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "test-report.schema.json",
  "title": "TestReport",
  "description": "exec_agent 产出 — 测试执行总报告",
  "type": "object",
  "required": ["run_id", "product_id", "timestamp", "summary", "results"],
  "additionalProperties": false,
  "properties": {
    "run_id": { "type": "string" },
    "product_id": { "type": "string" },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "model_used": {
      "type": "string",
      "description": "实际路由到的模型（含 fallback 情况）"
    },
    "execution_entry": { "type": "string" },
    "assertion_template_source": { "type": "string" },
    "assertion_templates_used": { "type": "array" },
    "failure_category_source": { "type": "string" },
    "governance_source": { "type": "string" },
    "governance_warning_count": { "type": "integer", "minimum": 0 },
    "planned_page_key_count": { "type": "integer", "minimum": 0 },
    "session_reused": { "type": "boolean" },
    "side_effect_probes": {
      "type": "object",
      "additionalProperties": true
    },
    "html_report": { "type": "string" },
    "summary": {
      "type": "object",
      "required": ["total", "passed", "failed", "skipped", "error"],
      "additionalProperties": false,
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "skipped": { "type": "integer", "minimum": 0 },
        "error": { "type": "integer", "minimum": 0 },
        "pass_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "defect_detection_rate": {
          "type": ["number", "null"],
          "description": "缺陷检出率（需人工评估后填写）"
        },
        "business_coverage": {
          "type": "object",
          "required": ["covered", "coverage_gap", "coverage_rate"],
          "additionalProperties": false,
          "properties": {
            "covered": { "type": "integer", "minimum": 0 },
            "coverage_gap": { "type": "integer", "minimum": 0 },
            "coverage_rate": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        }
      }
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["case_id", "path_id", "status"],
        "additionalProperties": true,
        "properties": {
          "case_id": { "type": "string" },
          "path_id": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["passed", "failed", "skipped", "error"]
          },
          "execution_status": {
            "type": "string",
            "enum": ["passed", "failed", "skipped", "error", "blocked_by_agent3_contract", "blocked_by_agent3_script"]
          },
          "coverage_status": {
            "type": "string",
            "enum": ["covered", "coverage-gap", "blocked", "unknown"]
          },
          "failure_category": {
            "type": ["string", "null"],
            "enum": [
              "env_issue",
              "test_data",
              "product_bug",
              "script_bug",
              "flaky",
              "agent3_contract_blocked",
              "agent3_script_blocked",
              null
            ]
          },
          "contract_status": {
            "type": ["string", "null"],
            "enum": ["compiled", "probe_required", "blocked", null]
          },
          "script_status": {
            "type": ["string", "null"],
            "enum": ["pending_generation", "generated", "invalid", "probe_required", "blocked", null]
          },
          "script_validation_status": {
            "type": ["string", "null"],
            "enum": ["not_run", "passed", "failed", "skipped", null]
          },
          "target_node": { "type": ["string", "null"] },
          "blocked_node": { "type": ["string", "null"] },
          "blocked_reason": { "type": ["string", "null"] },
          "page_keys": { "type": "array" },
          "error_message": { "type": ["string", "null"] },
          "visible_browser": { "type": "boolean" },
          "execution_entry": { "type": "string" },
          "execution_artifacts_dir": { "type": "string" },
          "fact_lineage": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "version": { "type": "string" },
              "scenario_id": { "type": "string" },
              "path_id": { "type": "string" },
              "case_ids": { "type": "array", "items": { "type": "string" } },
              "test_data_profile_ids": { "type": "array", "items": { "type": "string" } },
              "action_evidence": { "type": "object", "additionalProperties": true },
              "assertion_refs": { "type": "array", "items": { "type": "string" } },
              "terminal_boundary": { "type": "object", "additionalProperties": true },
              "coverage_status": { "type": "string" },
              "contract_status": { "type": "string" }
            }
          },
          "assertion_template": { "type": ["string", "null", "object"] },
          "assertion_template_source": { "type": "string" },
          "failure_category_source": { "type": "string" },
          "duration_s": { "type": "number" },
          "healing_applied": { "type": "boolean", "default": false }
        }
      }
    },
    "quarantine_summary": {
      "type": "object",
      "required": ["total", "blocking", "by_category", "by_status"],
      "additionalProperties": false,
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "blocking": { "type": "integer", "minimum": 0 },
        "by_category": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "by_status": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "cost_usd": {
      "type": ["number", "null"],
      "description": "本次 run 的 LLM 费用（由 LiteLLM 追踪）"
    }
  }
}
