{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "conflicts.schema.json",
  "title": "Conflicts",
  "description": "tc_merge_agent 产出 — 用例合并中发现的冲突列表",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["conflict_id", "type", "policy", "manual_case_id", "ac_case_id", "suggestion", "reason", "evidence", "owner"],
    "additionalProperties": false,
    "properties": {
      "conflict_id": {
        "type": "string",
        "description": "唯一冲突 ID，格式 CONFLICT-{seq}"
      },
      "type": {
        "type": "string",
        "enum": [
          "assertion_mismatch",
          "step_contradiction",
          "precondition_conflict",
          "scope_overlap",
          "missing_coverage"
        ]
      },
      "policy": {
        "type": "string",
        "enum": [
          "temporary-override",
          "update-human-case",
          "update-prd",
          "update-knowledge-base",
          "needs-product-confirmation"
        ],
        "description": "冲突解决策略（5 种）"
      },
      "manual_case_id": {
        "type": ["string", "null"],
        "description": "冲突涉及的人工用例 ID"
      },
      "ac_case_id": {
        "type": ["string", "null"],
        "description": "冲突涉及的 AC 推导用例 ID"
      },
      "description": { "type": "string" },
      "suggestion": { "type": "string" },
      "reason": { "type": "string" },
      "evidence": {
        "type": "object",
        "additionalProperties": true
      },
      "owner": { "type": "string" },
      "resolution_note": {
        "type": ["string", "null"],
        "description": "解决说明（R1 Gate 审核后填写）"
      },
      "resolved": {
        "type": "boolean",
        "default": false
      }
    }
  }
}
