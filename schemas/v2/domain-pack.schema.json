{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pxf77.github.io/e2e-test/schemas/v2/domain-pack.schema.json",
  "title": "Domain Pack v2",
  "description": "行业领域包契约，描述 ontology、state deps、assertion pack、data pack 与领域扩展入口。",
  "type": "object",
  "required": ["id", "name", "version"],
  "additionalProperties": true,
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
    "name": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "extends": {
      "type": "array",
      "items": {"type": "string"},
      "default": []
    },
    "ontology": {"type": "string"},
    "state_deps": {"type": "string"},
    "assertion_pack": {"type": "string"},
    "data_pack": {"type": "string"},
    "workflow_overrides": {"type": "string"},
    "business_terms": {
      "type": "object",
      "additionalProperties": {"type": "string"}
    },
    "page_types": {
      "type": "array",
      "items": {"type": "string"}
    },
    "supported_workflows": {
      "type": "array",
      "items": {"type": "string"}
    },
    "prompts": {
      "type": "object",
      "additionalProperties": {"type": "string"}
    }
  }
}
