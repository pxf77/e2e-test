{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pxf77.github.io/e2e-test/schemas/v2/state-machine.schema.json",
  "title": "Business State Machine v2",
  "description": "领域状态、事件、转移和终态契约。",
  "type": "object",
  "required": ["id", "states", "transitions"],
  "additionalProperties": true,
  "properties": {
    "id": {"type": "string"},
    "initial_state": {"type": "string"},
    "states": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "terminal_states": {"type": "array", "items": {"type": "string"}},
    "transitions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to"],
        "properties": {
          "from": {"type": "string"},
          "to": {"type": "string"},
          "event": {"type": "string"},
          "guard": {"type": "string"}
        }
      }
    }
  }
}
