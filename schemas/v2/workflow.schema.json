{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pxf77.github.io/e2e-test/schemas/v2/workflow.schema.json",
  "title": "Workflow DSL v2",
  "description": "可配置 E2E 回归工作流契约，描述节点、边、Gate、输入输出契约与运行策略。",
  "type": "object",
  "required": ["id", "version", "nodes", "edges"],
  "additionalProperties": true,
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
    "version": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "inputs": {"type": "object", "additionalProperties": true},
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/definitions/node"}
    },
    "edges": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/definitions/edge"}
    }
  },
  "definitions": {
    "node": {
      "type": "object",
      "required": ["id", "type", "implementation"],
      "additionalProperties": true,
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_:-]*$"},
        "type": {"type": "string", "enum": ["agent", "gate", "runner", "plugin", "report", "utility"]},
        "implementation": {"type": "string"},
        "policy": {"type": "string"},
        "when": {"type": "string"},
        "uses": {"type": "array", "items": {"type": "string"}},
        "inputs": {"type": "array", "items": {"type": "string"}},
        "outputs": {"type": "array", "items": {"type": "string"}}
      }
    },
    "edge": {
      "type": "object",
      "required": ["from", "to"],
      "additionalProperties": false,
      "properties": {
        "from": {"type": "string"},
        "to": {"type": "string"},
        "on": {"type": "string"}
      }
    }
  }
}
