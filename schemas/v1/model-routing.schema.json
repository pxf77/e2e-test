{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pxf77.github.io/e2e-test/schemas/v1/model-routing.schema.json",
  "title": "ModelRouting",
  "description": "NEW (v3.1) — config/model-routing.yaml 的格式规范",
  "type": "object",
  "required": ["version", "agents"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string" },
    "agents": {
      "type": "object",
      "propertyNames": {
        "enum": ["tc_merge", "path_extract", "explore", "exec_healing"]
      },
      "additionalProperties": {
        "type": "object",
        "required": ["primary"],
        "additionalProperties": false,
        "properties": {
          "primary": {
            "type": "string",
            "description": "主模型（LiteLLM 格式，如 claude-sonnet-4-6）"
          },
          "reasoning_effort": {
            "type": "string",
            "enum": ["none", "minimal", "low", "medium", "high", "xhigh", "default"],
            "description": "模型推理强度；按 LiteLLM reasoning_effort 参数透传。"
          },
          "fallback": {
            "type": "array",
            "items": { "type": "string" },
            "default": []
          }
        }
      }
    },
    "litellm": {
      "type": "object",
      "properties": {
        "request_timeout": { "type": "integer" },
        "num_retries": { "type": "integer" },
        "drop_params": { "type": "boolean" },
        "max_budget": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        }
      }
    }
  }
}
