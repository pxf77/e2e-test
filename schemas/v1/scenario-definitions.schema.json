{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pxf77.github.io/e2e-test/schemas/v1/scenario-definitions.schema.json",
  "title": "ScenarioDefinitions",
  "description": "mpt-ins-ts-gen 阶段二产出 — 测试场景定义，支持当前 reg/script-plan/scenarios.json 列表产物",
  "oneOf": [
    {
      "type": "array",
      "items": { "$ref": "#/definitions/scenario" }
    },
    {
      "type": "object",
      "required": ["product", "scenarios"],
      "additionalProperties": false,
      "properties": {
        "product": { "type": "string" },
        "scenarios": {
          "type": "array",
          "items": { "$ref": "#/definitions/scenario" }
        }
      }
    }
  ],
  "definitions": {
    "scenario": {
      "type": "object",
      "required": ["scenario_id", "name", "path_id", "variants"],
      "additionalProperties": true,
      "properties": {
        "scenario_id": { "type": "string" },
        "name": { "type": "string" },
        "path_id": { "type": "string" },
        "priority": {
          "type": "string",
          "enum": ["P0", "P1", "P2"]
        },
        "entry_url": { "type": ["string", "null"] },
        "route_nodes": { "type": "array", "items": { "type": "string" } },
        "page_keys": { "type": "array" },
        "case_ids": { "type": "array", "items": { "type": "string" } },
        "planned_page_refs": { "type": "array", "items": { "type": "string" } },
        "page_content_refs": { "type": "array", "items": { "type": "string" } },
        "target_node": { "type": ["string", "null"] },
        "node_progress": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "completion_rule": { "type": "object", "additionalProperties": true },
        "page_element_plan": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "mock_data": { "type": "object", "additionalProperties": true },
        "real_actions": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "path_exploration_status": {
          "type": ["string", "null"],
          "enum": ["explored", "partial", "blocked", null]
        },
        "contract_status": {
          "type": "string",
          "enum": ["compiled", "probe_required", "blocked"]
        },
        "script_status": {
          "type": "string",
          "enum": ["pending_generation", "generated", "invalid", "probe_required", "blocked"]
        },
        "script_validation_status": {
          "type": "string",
          "enum": ["not_run", "passed", "failed", "skipped"]
        },
        "runtime_status": {
          "type": "string",
          "enum": ["not_executed", "passed", "failed", "skipped", "error"]
        },
        "script_validation": { "type": "object", "additionalProperties": true },
        "coverage_status": {
          "type": "string",
          "enum": ["covered", "coverage-gap", "blocked", "unknown"]
        },
        "blocked_node": { "type": ["string", "null"] },
        "blocked_reason": { "type": ["string", "null"] },
        "terminal_boundary": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "source": { "type": "string" },
            "boundary_node": { "type": ["string", "null"] },
            "target_node": { "type": ["string", "null"] },
            "classification": { "type": "string" },
            "path_status": { "type": ["string", "null"] },
            "blocked_reason": { "type": ["string", "null"] }
          }
        },
        "resume_condition": { "type": ["string", "null"] },
        "evidence_source": { "type": ["string", "null"] },
        "fact_lineage": { "$ref": "#/definitions/fact_lineage" },
        "variants": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["variant_id", "conditions", "test_data_profile_ids"],
            "properties": {
              "variant_id": { "type": "string" },
              "conditions": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              },
              "test_data_profile_ids": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "spec_path": { "type": "string" },
        "estimated_duration_s": { "type": ["number", "null"] }
      }
    },
    "fact_lineage": {
      "type": "object",
      "required": ["version", "scenario_id", "path_id", "case_ids"],
      "additionalProperties": true,
      "properties": {
        "version": { "type": "string" },
        "scenario_id": { "type": "string" },
        "path_id": { "type": "string" },
        "case_ids": { "type": "array", "items": { "type": "string" } },
        "source_case_ids": { "type": "array", "items": { "type": "string" } },
        "condition_keys": { "type": "array", "items": { "type": "string" } },
        "test_data_profile_ids": { "type": "array", "items": { "type": "string" } },
        "page_content_refs": { "type": "array", "items": { "type": "string" } },
        "planned_page_refs": { "type": "array", "items": { "type": "string" } },
        "action_evidence": { "type": "object", "additionalProperties": true },
        "assertion_refs": { "type": "array", "items": { "type": "string" } },
        "terminal_boundary": { "type": "object", "additionalProperties": true },
        "coverage_status": { "type": "string" },
        "contract_status": { "type": "string" }
      }
    }
  }
}
