{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pxf77.github.io/e2e-test/schemas/v1/regression-paths.schema.json",
  "title": "RegressionPaths",
  "description": "path_extract_agent 产出 — 枚举后的回归测试路径列表",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["path_id", "case_ids", "nodes"],
    "additionalProperties": false,
    "properties": {
      "path_id": {
        "type": "string",
        "description": "唯一路径 ID，格式 PATH-{seq}"
      },
      "case_ids": {
        "type": "array",
        "items": { "type": "string" },
        "description": "此路径覆盖的用例 ID 列表"
      },
      "nodes": {
        "type": "array",
        "items": { "type": "string" },
        "description": "路径经过的节点 ID 序列"
      },
      "optional_nodes": {
        "type": "array",
        "description": "最大业务路径中可选节点；Agent4 遇到产品不包含该页面时可跳过",
        "items": { "type": "string" }
      },
      "execution_policy": {
        "type": "object",
        "description": "路径执行策略，控制 Agent4 对可选节点的跳过行为",
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "skip_absent_optional_nodes": { "type": "boolean" }
        }
      },
      "business_intent": {
        "type": ["string", "null"],
        "description": "业务意图，用于把用例映射到稳定的 planned page chain"
      },
      "scenario_type": {
        "type": ["string", "null"],
        "description": "业务场景类型，供 Agent3/Agent4 选择执行策略"
      },
      "conditions": {
        "type": "object",
        "description": "此路径的前提条件（键值对）",
        "additionalProperties": { "type": "string" }
      },
      "condition_sets": {
        "type": "array",
        "description": "路径去重后合并的原始条件集合",
        "items": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      },
      "assertions": {
        "type": "array",
        "description": "路径继承的断言集合",
        "items": {}
      },
      "rules": {
        "type": "array",
        "description": "路径继承的业务规则集合",
        "items": {}
      },
      "coverage_refs": {
        "type": "array",
        "description": "路径覆盖来源引用",
        "items": {}
      },
      "data_variants": {
        "type": "array",
        "description": "路径数据变体集合",
        "items": {}
      },
      "page_keys": {
        "type": "array",
        "description": "Agent2 规划出的 page-key 治理结果，供 Agent3 对齐真实页面",
        "items": {
          "type": "object",
          "required": ["node_id", "page_key", "state", "allowed_state_keys", "matched_whitelist_patterns"],
          "additionalProperties": false,
          "properties": {
            "node_id": { "type": "string" },
            "url_pattern": { "type": ["string", "null"] },
            "page_key": { "type": "string" },
            "state": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "allowed_state_keys": {
              "type": "array",
              "items": { "type": "string" }
            },
            "matched_whitelist_patterns": {
              "type": "array",
              "items": { "type": "string" }
            },
            "rejected_state_keys": {
              "type": "array",
              "items": { "type": "string" }
            },
            "hot_value_expansions": {
              "type": "object",
              "additionalProperties": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      },
      "matched_whitelist_patterns": {
        "type": "array",
        "description": "路径级命中的 state-deps 白名单 pattern 汇总",
        "items": { "type": "string" }
      },
      "warnings": {
        "type": "array",
        "description": "路径级治理告警",
        "items": { "type": "string" }
      },
      "priority": {
        "type": "string",
        "enum": ["P0", "P1", "P2"],
        "default": "P0"
      },
      "estimated_duration_s": {
        "type": ["number", "null"],
        "description": "预估执行时间（秒）"
      },
      "dedupe_key": {
        "type": "string",
        "description": "忽略 start/end/branch 后的路径去重键"
      },
      "source_path_count": {
        "type": "integer",
        "minimum": 1,
        "description": "去重后合并的原始路径数量"
      }
    }
  }
}
