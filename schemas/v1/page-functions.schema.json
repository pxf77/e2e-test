{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pxf77.github.io/e2e-test/schemas/v1/page-functions.schema.json",
  "title": "PageFunctions",
  "description": "explore_agent 产出 — 生成的页面函数元数据列表",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["page_id", "function_name", "file_path", "params", "verified"],
    "additionalProperties": false,
    "properties": {
      "page_id": { "type": "string" },
      "function_name": {
        "type": "string",
        "pattern": "^fill[A-Z]"
      },
      "file_path": {
        "type": "string",
        "description": "相对于 products/{product}/ts-gen/page-functions/ 的路径"
      },
      "params": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["name", "type"],
          "properties": {
            "name": { "type": "string" },
            "type": { "type": "string" },
            "description": { "type": "string" },
            "required": { "type": "boolean", "default": true }
          }
        }
      },
      "verified": {
        "type": "boolean",
        "description": "是否通过 leaf-verify + entry-chain-verify"
      },
      "source": {
        "type": "string",
        "enum": ["agent3.trace", "agent2.flow"],
        "description": "page function 来源；优先从 Agent3 真实 trace 编译"
      },
      "fields": {
        "type": "array",
        "description": "Agent3 真实 DOM 字段与 selector fallback 信息",
        "items": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "field_key": { "type": "string" },
            "selector": { "type": ["string", "null"] },
            "tag": { "type": ["string", "null"] },
            "type": { "type": ["string", "null"] },
            "label": { "type": ["string", "null"] },
            "mock_value": { "type": ["string", "number", "boolean", "null"] }
          }
        }
      },
      "actions": {
        "type": "array",
        "description": "Agent3 成功动作 trace 与 DOM action fallback",
        "items": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "text": { "type": ["string", "null"] },
            "selector": { "type": ["string", "null"] },
            "text_selector": { "type": ["string", "null"] },
            "tag": { "type": ["string", "null"] },
            "href": { "type": ["string", "null"] },
            "source": { "type": "string" }
          }
        }
      },
      "entry_signals": {
        "type": "array",
        "items": { "type": "string" },
        "description": "expectXxxPage 使用的页面信号"
      },
      "exit_signals": {
        "type": "array",
        "items": { "type": "string" },
        "description": "当前页面可推进信号"
      },
      "next_node_id": {
        "type": ["string", "null"],
        "description": "assertNextPage 对应的下一业务节点"
      },
      "next_signals": {
        "type": "array",
        "items": { "type": "string" },
        "description": "assertNextPage 使用的下一页信号"
      },
      "trace_events": {
        "type": "array",
        "items": { "type": "object", "additionalProperties": true },
        "description": "Agent3 observe/act/verify 原始事件"
      },
      "branches": {
        "type": "array",
        "items": { "type": "string" },
        "description": "此页面的分支变体列表"
      }
    }
  }
}
