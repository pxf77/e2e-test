{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "regression-flow.schema.json",
  "title": "RegressionFlow",
  "description": "path_extract_agent 产出 — 业务流程树（用于路径枚举）",
  "type": "object",
  "required": ["product_id", "entry_url", "flow_version", "nodes", "edges"],
  "additionalProperties": false,
  "properties": {
    "product_id": { "type": "string" },
    "entry_url": {
      "type": "string",
      "format": "uri"
    },
    "flow_version": { "type": "string" },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["node_id", "page_name", "type"],
        "properties": {
          "node_id": { "type": "string" },
          "page_name": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["start", "form", "confirm", "payment", "result", "branch", "end"]
          },
          "url_pattern": { "type": "string" },
          "is_terminal": { "type": "boolean" }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "condition": {
            "type": ["string", "null"],
            "description": "触发此边的条件（如 plan_type=A）"
          }
        }
      }
    }
  }
}
